# Copy this file to `.env` and fill in your real credentials.
# `.env` is gitignored — secrets are never committed.

# Legacy TMS (provided out-of-band by HappyRobot)
TMS_HOST=your-tms-host.example.com
TMS_PORT=00000
TMS_TOKEN=replace-with-your-tms-token

# FMCSA QCMobile API (webKey)
FMCSA_API_KEY=replace-with-your-fmcsa-webkey
# live = real QCMobile (needs a US IP; geo-blocked elsewhere).
# mock = deterministic verdict for local dev. Use 'live' on the US deploy.
FMCSA_MODE=live

# Bridge auth: the API key the platform's webhooks must send as X-API-Key.
# Generate a strong one: python -c "import secrets; print(secrets.token_urlsafe(32))"
BRIDGE_API_KEY=replace-with-a-strong-random-key

# OTP identity check. The code is delivered to the contact on file via the platform's
# email/SMS node; OTP_ON_FILE_PHONE is that on-file contact for the demo.
OTP_ON_FILE_PHONE=+10000000000

# Optional (sensible defaults in config.py)
# TMS_TIMEOUT=8.0
# TMS_RETRIES=3
# FMCSA_TIMEOUT=10.0
# NEG_ALPHA=0.08
# NEG_MAX_ROUNDS=3
# NEG_STEP=25
# NEG_TTL_SECONDS=1800
# OTP_TTL_SECONDS=600
# OTP_MAX_ATTEMPTS=3
# OTP_FIXED_CODE=000000   # test fixture accepted unconditionally; leave blank to disable in prod
